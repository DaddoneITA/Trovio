generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  stripeId      String?
  plan          String    @default("free")
  aiProvider    String    @default("")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  searches   Search[]
  savedLeads SavedLead[]
  messages   GeneratedMessage[]
  keywords   MonitoredKeyword[]
  aiCredentials AiCredential[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiCredential {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Search {
  id            String   @id @default(cuid())
  userId        String
  query         String
  subreddits    String[]
  timeFilter    String   @default("week")
  resultsCount  Int
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedLead {
  id        String   @id @default(cuid())
  userId    String
  redditId  String
  title     String
  url       String
  subreddit String
  snippet   String?
  savedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, redditId])
}

model GeneratedMessage {
  id           String   @id @default(cuid())
  userId       String
  leadRedditId String?
  service      String
  message      String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MonitoredKeyword {
  id            String   @id @default(cuid())
  userId        String
  keyword       String
  subreddits    String[]
  active        Boolean  @default(true)
  lastCheckedAt DateTime?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
